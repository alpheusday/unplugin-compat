{
    "$schema": "https://raw.githubusercontent.com/vitejs/vite-plugin-registry/refs/heads/main/data/schema/extended-package-json.schema.json",
    "name": "unplugin-compat",
    "version": "0.1.0",
    "description": "A plugin for JavaScript compatibility",
    "keywords": [
        "compat",
        "vite",
        "vite-plugin",
        "rolldown",
        "rolldown-plugin",
        "unplugin",
        "ts",
        "typescript",
        "js",
        "javascript"
    ],
    "homepage": "https://github.com/alpheusday/unplugin-compat",
    "bugs": "https://github.com/alpheusday/unplugin-compat/issues",
    "repository": {
        "type": "git",
        "url": "https://github.com/alpheusday/unplugin-compat.git",
        "directory": "package"
    },
    "license": "MIT",
    "author": {
        "name": "Alpheus",
        "email": "contact@alphe.us"
    },
    "exports": {
        "./rolldown": {
            "types": "./dist/rolldown.d.ts",
            "import": "./dist/rolldown.mjs",
            "require": "./dist/rolldown.js"
        },
        "./vite": {
            "types": "./dist/vite.d.ts",
            "import": "./dist/vite.mjs",
            "require": "./dist/vite.js"
        },
        "./plugins/config": {
            "types": "./dist/plugins/config.d.ts",
            "import": "./dist/plugins/config.mjs",
            "require": "./dist/plugins/config.js"
        },
        "./plugins/transform": {
            "types": "./dist/plugins/transform.d.ts",
            "import": "./dist/plugins/transform.mjs",
            "require": "./dist/plugins/transform.js"
        },
        "./plugins/minify": {
            "types": "./dist/plugins/minify.d.ts",
            "import": "./dist/plugins/minify.mjs",
            "require": "./dist/plugins/minify.js"
        },
        "./functions/tsconfig": {
            "types": "./dist/functions/tsconfig.d.ts",
            "import": "./dist/functions/tsconfig.mjs",
            "require": "./dist/functions/tsconfig.js"
        },
        "./package.json": "./package.json"
    },
    "main": "./dist/rolldown.js",
    "module": "./dist/rolldown.mjs",
    "types": "./dist/rolldown.d.ts",
    "files": [
        "dist"
    ],
    "dependencies": {
        "@swc/core": "catalog:dep",
        "es-toolkit": "^1.40.0",
        "get-tsconfig": "catalog:dep",
        "ts-vista": "~0.2.3",
        "unplugin": "catalog:dep"
    },
    "devDependencies": {
        "rolldown": "catalog:dev",
        "vite": "catalog:dev"
    },
    "peerDependencies": {
        "rolldown": "catalog:peer",
        "vite": "catalog:peer"
    },
    "peerDependenciesMeta": {
        "rolldown": {
            "optional": true
        },
        "vite": {
            "optional": true
        }
    },
    "compatiblePackages": {
        "schemaVersion": 1,
        "rollup": {
            "type": "incompatible",
            "reason": "Uses Rolldown-specific APIs"
        },
        "rolldown": {
            "type": "compatible",
            "versions": "^1.0.0"
        },
        "vite": {
            "type": "compatible",
            "versions": "^8.0.0"
        }
    }
}
